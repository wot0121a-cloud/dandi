---
import '../styles/global.css';
import siteData from '../data/site-data.json';
import Icon from '../components/Icon.astro';

const { navItems } = siteData;

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Dandy's World Magyar Rajongói Oldal", 
	description = "Karakter statisztikák, Toon-kapcsolatok, Twisted túlélési tippek és rajongói teóriák magyarul." 
} = Astro.props;

const fullTitle = title.includes("Dandy's World") ? title : `${title} | Dandy's World Magyar Rajongói Oldal`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{fullTitle}</title>
		<meta name="title" content={fullTitle} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/og-image.jpg', Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={fullTitle} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL('/og-image.jpg', Astro.url)} />

		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url} />

		<!-- Google Search Console Placeholder -->
		<meta name="google-site-verification" content="GSC_ID_PLACEHOLDER" />

		<!-- Global site tag (gtag.js) - Google Analytics Placeholder -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=GA_ID_PLACEHOLDER"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'GA_ID_PLACEHOLDER');
		</script>
	</head>
	<body>
		<header class="site-header">
			<div class="container h-full flex items-center justify-between">
				<a href="/" class="brand">
					<div class="logo-box">D</div>
					<span class="brand-text">Dandy's Hub</span>
				</a>
				
				<button class="mobile-toggle" aria-label="Menü megnyitása" id="menuToggle">
					<span class="bar bar-1"></span>
					<span class="bar bar-2"></span>
					<span class="bar bar-3"></span>
				</button>

				<nav class="nav-menu" id="navMenu">
					{navItems.map((item) => {
						const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
						return (
							<a href={item.href} class={`nav-link ${isActive ? 'active' : ''}`}>
								<Icon name={item.icon || 'info'} size={18} />
								<span>{item.label}</span>
							</a>
						);
					})}
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container">
				<div class="footer-icon">👥</div>
				<p class="copyright">© 2026 Dandy's World Magyar Rajongói Oldal</p>
				<p class="disclaimer">
					Ez egy rajongók által készített, nem hivatalos weboldal. A Dandy's World,
					a karakterek és a játék grafikai elemei az eredeti fejlesztők tulajdonát képezik.
				</p>
			</div>
		</footer>

		<script>
			const menuToggle = document.getElementById('menuToggle');
			const navMenu = document.getElementById('navMenu');

			menuToggle?.addEventListener('click', () => {
				menuToggle.classList.toggle('active');
				navMenu?.classList.toggle('active');
				document.body.classList.toggle('menu-open');
			});
		</script>

		<style>
			.h-full { height: 100%; }
			.flex { display: flex; }
			.items-center { align-items: center; }
			.justify-between { justify-content: space-between; }

			.brand {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				font-size: 1.25rem;
				font-weight: 900;
				color: hsl(var(--text-primary));
				z-index: 1001;
			}

			.logo-box {
				width: 40px;
				height: 40px;
				border-radius: 12px;
				background: linear-gradient(135deg, hsl(var(--accent-primary)), hsl(var(--accent-secondary)));
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-size: 1.25rem;
				box-shadow: 0 4px 12px hsla(var(--accent-primary), 0.3);
			}

			/* Navigation */
			.mobile-toggle {
				display: flex;
				flex-direction: column;
				gap: 5px;
				background: none;
				border: none;
				padding: 10px;
				cursor: pointer;
				z-index: 1001;
			}

			@media (min-width: 768px) {
				.mobile-toggle { display: none; }
			}

			.bar {
				width: 24px;
				height: 3px;
				background: hsl(var(--text-primary));
				border-radius: 3px;
				transition: all 0.3s ease;
			}

			.mobile-toggle.active .bar-1 { transform: translateY(8px) rotate(45deg); }
			.mobile-toggle.active .bar-2 { opacity: 0; }
			.mobile-toggle.active .bar-3 { transform: translateY(-8px) rotate(-45deg); }

			.nav-menu {
				position: fixed;
				top: 0;
				right: -100%;
				width: 100%;
				height: 100vh;
				background: white;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 2rem;
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				z-index: 1000;
			}

			.nav-menu.active {
				right: 0;
			}

			@media (min-width: 768px) {
				.nav-menu {
					position: static;
					width: auto;
					height: auto;
					background: none;
					flex-direction: row;
					gap: 0.5rem;
				}
			}

			.nav-link {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.6rem 1.25rem;
				border-radius: var(--radius-btn);
				font-weight: 700;
				font-size: 1.125rem;
				color: hsl(var(--text-secondary));
				transition: all 0.2s ease;
			}

			@media (min-width: 768px) {
				.nav-link {
					font-size: 0.875rem;
				}
			}

			.nav-link:hover {
				background-color: hsl(var(--bg-primary));
				color: hsl(var(--text-primary));
			}
			
			.nav-link.active {
				background-color: hsl(var(--accent-primary), 0.1);
				color: hsl(var(--accent-primary));
			}

			.footer-icon {
				font-size: 2rem;
				margin-bottom: 1rem;
				display: inline-block;
				transform: rotate(12deg);
			}

			.copyright {
				font-weight: 900;
				margin-bottom: 0.5rem;
			}

			.disclaimer {
				font-size: 0.875rem;
				color: hsl(var(--text-secondary));
				max-width: 600px;
				margin: 0 auto;
			}
		</style>
	</body>
</html>
