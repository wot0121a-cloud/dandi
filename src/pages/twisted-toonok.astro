---
import BaseLayout from '../layouts/BaseLayout.astro';
import { twisteds } from '../data/site-data.json';

const title = "Twisted Toonok & Túlélési Tippek";
const description = "Ismerd meg a Twisted változataikat! Hogyan kerüld el őket, mik a gyenge pontjaik, és hogyan éld túl a velük való találkozást.";
---

<BaseLayout title={title} description={description}>
	<div class="header">
		<h1 class="twisted-glow">Twisted Toonok</h1>
		<p>A Toonok sötét oldala. Vigyázz, ne kerülj a látóterükbe!</p>
	</div>

	<div class="twisted-grid">
		{twisteds.map((twisted) => (
			<article class="twisted-card" id={twisted.id}>
				<div class="card-inner">
					<div class="top-section">
						<div class="danger-indicator">
							<span class="danger-label">VESZÉLYESSÉG:</span>
							<span class={`danger-value danger-${twisted.danger.toLowerCase()}`}>{twisted.danger}</span>
						</div>
						<h2 class="twisted-name">{twisted.name}</h2>
					</div>
					
					<div class="twisted-img-wrapper" style={`border-bottom: 2px solid var(--color-${twisted.accent});`}>
						<img src={`/images/characters/${twisted.id}.png`} alt={`${twisted.name} Twisted változat`} class="twisted-img" loading="lazy" />
						<span class="attribution">Forrás: Dandy's World Fandom Wiki</span>
					</div>

					<div class="mechanic-box">
						<h3 class="box-title">Hogyan működik?</h3>
						<p>{twisted.mechanic}</p>
					</div>

					<div class="tip-box" style={`border-left: 4px solid var(--color-${twisted.accent})`}>
						<h3 class="box-title">Túlélési tipp</h3>
						<p>{twisted.tip}</p>
					</div>
				</div>
			</article>
		))}
	</div>

	<style>
		.header {
			margin-bottom: 5rem;
			text-align: center;
		}

		.twisted-glow {
			font-size: 3.5rem;
			color: hsl(var(--text-primary));
			text-shadow: 0 0 20px hsla(var(--accent-primary), 0.1);
		}

		.twisted-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 1.5rem;
		}

		.twisted-card {
			background: #111;
			background: linear-gradient(145deg, #1a1a1a, #0a0a0a);
			color: #eee;
			border-radius: 32px;
			padding: 1.5rem;
			position: relative;
			overflow: hidden;
			border: 1px solid #333;
			transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		}

		@media (min-width: 768px) {
			.twisted-card {
				padding: 2.5rem;
			}
		}

		.twisted-card:hover {
			transform: translateY(-10px) scale(1.01);
			border-color: #555;
			box-shadow: 0 30px 60px rgba(0,0,0,0.5);
		}

		.danger-indicator {
			margin-bottom: 0.5rem;
			display: flex;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.75rem;
			font-weight: 900;
		}

		.danger-label {
			opacity: 0.5;
		}

		.danger-value {
			padding: 0.15rem 0.5rem;
			border-radius: 6px;
		}

		.danger-extrém { color: #f43f5e; background: rgba(244, 63, 94, 0.15); }
		.danger-magas { color: #f59e0b; background: rgba(245, 158, 11, 0.15); }
		.danger-közepes { color: #10b981; background: rgba(16, 185, 129, 0.15); }

		.twisted-name {
			font-size: 2.25rem;
			margin-bottom: 2rem;
			letter-spacing: -0.03em;
		}

		.mechanic-box, .tip-box {
			background: rgba(255, 255, 255, 0.03);
			padding: 1.5rem;
			border-radius: 20px;
			margin-bottom: 1.5rem;
		}

		.box-title {
			font-size: 0.625rem;
			font-weight: 900;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			margin-bottom: 0.75rem;
			opacity: 0.6;
		}

		.mechanic-box p, .tip-box p {
			margin: 0;
			font-size: 0.95rem;
			line-height: 1.5;
		}

		.tip-box {
			background: rgba(255, 255, 255, 0.05);
			margin-bottom: 0;
		}

		.twisted-img-wrapper {
			width: 100%;
			height: 250px;
			background: repeating-linear-gradient(45deg, #111 0, #111 10px, #1a1a1a 10px, #1a1a1a 20px);
			border-radius: 20px;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
			margin-bottom: 1.5rem;
			position: relative;
		}
		
		.twisted-img-wrapper::after {
			content: '';
			position: absolute;
			inset: 0;
			background: radial-gradient(circle, transparent 40%, rgba(0,0,0,0.8) 100%);
			pointer-events: none;
		}
		
		.twisted-img {
			width: auto;
			height: 120%;
			object-fit: contain;
			filter: drop-shadow(0 20px 30px rgba(0,0,0,0.8)) sepia(0.3) hue-rotate(-10deg) saturate(0.8) brightness(0.8);
			transition: all 0.3s ease;
		}

		.attribution {
			position: absolute;
			bottom: 10px;
			right: 15px;
			font-size: 0.6rem;
			color: #fff;
			opacity: 0.3;
			font-style: italic;
			z-index: 2;
		}
		
		.twisted-card:hover .twisted-img {
			filter: drop-shadow(0 20px 30px rgba(0,0,0,0.8)) sepia(0) hue-rotate(0) saturate(1) brightness(1);
			transform: scale(1.05);
		}
	</style>
</BaseLayout>
