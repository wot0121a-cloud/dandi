---
import BaseLayout from '../layouts/BaseLayout.astro';
import { toonCards } from '../data/site-data.json';

const featuredCards = toonCards.filter(card => card.featured);
---

<BaseLayout>
	<section class="hero">
		<h1 class="hero-title">Dandy's World <span class="highlight">Magyarul</span></h1>
		<p class="hero-subtitle">
			Fedezd fel a Gardenview Center titkait, ismerd meg a Toonokat, és éld túl a Twisted-ek támadását!
		</p>
		<div class="hero-btns">
			<a href="/karakterek" class="btn btn-primary">Karakterek böngészése</a>
			<a href="/toon-kapcsolatok" class="btn btn-outline">Teóriák & Kapcsolatok</a>
		</div>
	</section>

	<section class="featured">
		<div class="section-header">
			<h2 class="section-title">Kiemelt Hírek & Teóriák</h2>
			<p class="section-subtitle">A legfontosabb infók a Toon-világból.</p>
		</div>

		<div class="card-grid">
			{featuredCards.map((card) => (
				<article class={`card border-${card.color}`}>
					<div class="card-status">{card.status}</div>
					<h3 class="card-title">{card.title}</h3>
					<p class="card-desc">{card.description}</p>
					<a href="#" class="card-link">Tovább olvasok →</a>
				</article>
			))}
		</div>
	</section>

	<style>
		.hero {
			text-align: center;
			padding: 4rem 0 6rem;
		}

		.hero-title {
			font-size: 3.5rem;
			margin-bottom: 1.5rem;
		}

		.highlight {
			background: linear-gradient(135deg, hsl(var(--accent-primary)), hsl(var(--accent-secondary)));
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
		}

		.hero-subtitle {
			font-size: 1.25rem;
			color: hsl(var(--text-secondary));
			max-width: 700px;
			margin: 0 auto 2.5rem;
		}

		.hero-btns {
			display: flex;
			gap: 1rem;
			justify-content: center;
		}

		.btn {
			padding: 1rem 2rem;
			border-radius: 14px;
			font-weight: 900;
			font-size: 1rem;
			display: inline-block;
			transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		}

		.btn-primary {
			background-color: hsl(var(--text-primary));
			color: white;
			box-shadow: 0 10px 20px hsla(var(--text-primary), 0.2);
		}

		.btn-primary:hover {
			transform: translateY(-4px);
			box-shadow: 0 15px 30px hsla(var(--text-primary), 0.3);
		}

		.btn-outline {
			border: 2px solid hsl(var(--border-color));
			color: hsl(var(--text-primary));
		}

		.btn-outline:hover {
			background-color: hsl(var(--bg-secondary));
			border-color: hsl(var(--text-primary));
		}

		/* Featured Section */
		.featured {
			padding-bottom: 4rem;
		}

		.section-header {
			margin-bottom: 3rem;
		}

		.section-title {
			font-size: 2.5rem;
			margin-bottom: 0.5rem;
		}

		.section-subtitle {
			color: hsl(var(--text-secondary));
			font-size: 1.125rem;
		}

		.card-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
			gap: 2rem;
		}

		.card {
			padding: 2rem;
			background-color: hsl(var(--bg-secondary));
			border-radius: 24px;
			border: 1px solid hsl(var(--border-color));
			transition: all 0.3s ease;
			position: relative;
			overflow: hidden;
		}
		
		.card:hover {
			transform: translateY(-8px);
			box-shadow: 0 20px 40px var(--shadow-color);
		}

		.card-status {
			display: inline-block;
			padding: 0.25rem 0.75rem;
			border-radius: 20px;
			font-size: 0.75rem;
			font-weight: 900;
			text-transform: uppercase;
			margin-bottom: 1.25rem;
			background-color: hsl(var(--bg-primary));
		}

		.card-title {
			font-size: 1.5rem;
			margin-bottom: 1rem;
		}

		.card-desc {
			color: hsl(var(--text-secondary));
			margin-bottom: 1.5rem;
		}

		.card-link {
			font-weight: 900;
			color: hsl(var(--accent-primary));
			font-size: 0.875rem;
		}

		/* Card border colors */
		.border-sky { border-top: 6px solid #0ea5e9; }
		.border-rose { border-top: 6px solid #f43f5e; }
		.border-emerald { border-top: 6px solid #10b981; }
		.border-purple { border-top: 6px solid #a855f7; }
	</style>
</BaseLayout>
