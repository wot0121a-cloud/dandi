---
import BaseLayout from '../layouts/BaseLayout.astro';
import { toonCards } from '../data/site-data.json';

const title = "Toon-kapcsolatok és Teóriák";
const description = "Mélyedj el a Dandy's World lore-jában! Karakter kapcsolatok, rejtett utalások és a legérdekesebb rajongói teóriák egy helyen.";
---

<BaseLayout title={title} description={description}>
	<div class="header">
		<h1>Toon-kapcsolatok & Lore</h1>
		<p>Mi történt valójában a színfalak mögött? Közösségi elméletek és hivatalos tények.</p>
	</div>

	<div class="lore-grid">
		{toonCards.map((theory) => (
			<article class="lore-card" id={theory.id} style={`border-left: 4px solid var(--color-${theory.color})`}>
				
				<div class={`lore-img-wrapper ${!theory.featured ? 'no-img' : ''}`}>
					{theory.featured ? (
						<>
							<img src={`/images/cards/${theory.id}.png`} alt={`${theory.title} illusztráció`} class="lore-img" loading="lazy" />
							<span class="attribution">AI generált illusztráció</span>
						</>
					) : (
						<div class="placeholder-icon">
							<span class="icon">📜</span>
						</div>
					)}
				</div>

				<div class="card-meta">
					<span class={`status-tag tag-${theory.status.toLowerCase()}`}>{theory.status}</span>
				</div>
				<h2 class="theory-title">{theory.title}</h2>
				<p class="theory-content">{theory.description}</p>
				<div class="card-footer">
					<span class="read-more">Forrás: Játékon belüli utalások</span>
				</div>
			</article>
		))}
	</div>

	<section class="about-lore">
		<div class="lore-banner">
			<h2>Van egy saját teóriád?</h2>
			<p>A közösség ereje a közös gondolkodásban rejlik. Ha találtál egy rejtett üzenetet vagy egy érdekes összefüggést, ne tartsd magadban!</p>
			<a href="/rolunk" class="btn-lore">Vedd fel velünk a kapcsolatot</a>
		</div>
	</section>

	<style>
		.header {
			margin-bottom: 5rem;
			text-align: center;
		}

		.lore-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
			gap: 2.5rem;
			margin-bottom: 6rem;
		}

		.lore-card {
			background: white;
			border-radius: 24px;
			padding: 2.5rem;
			border: 1px solid hsl(var(--border-color));
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
			transition: all 0.3s ease;
			box-shadow: 0 4px 12px hsla(var(--shadow-color), 0.05);
			overflow: hidden;
		}

		.lore-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 20px 40px hsla(var(--shadow-color), 0.1);
		}
		
		.lore-img-wrapper {
			width: 100%;
			height: 180px;
			background: hsl(var(--bg-primary));
			border-radius: 16px;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
			margin-bottom: 0.5rem;
			border: 1px solid hsl(var(--border-color));
		}
		
		.lore-img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform 0.3s ease;
		}
		
		.no-img {
			background: linear-gradient(135deg, hsl(var(--bg-primary)), hsl(var(--bg-secondary)));
			opacity: 0.6;
		}
		
		.placeholder-icon {
			font-size: 3rem;
			filter: grayscale(1) opacity(0.3);
		}

		.attribution {
			position: absolute;
			bottom: 5px;
			right: 10px;
			font-size: 0.5rem;
			color: #fff;
			opacity: 0.4;
			font-style: italic;
			background: rgba(0,0,0,0.3);
			padding: 2px 6px;
			border-radius: 4px;
		}
		
		.lore-card:hover .lore-img {
			transform: scale(1.05);
		}

		.status-tag {
			font-size: 0.625rem;
			font-weight: 900;
			padding: 0.3rem 0.8rem;
			border-radius: 10px;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			display: inline-block;
		}

		.tag-hivatalos, .tag-tény { background: #dcfce7; color: #166534; }
		.tag-pletyka, .tag-ismeretlen { background: #fef9c3; color: #854d0e; }
		.tag-ellenséges { background: #fee2e2; color: #991b1b; }

		.theory-title {
			font-size: 1.75rem;
			line-height: 1.2;
		}

		.theory-content {
			color: hsl(var(--text-secondary));
			font-size: 1.05rem;
			line-height: 1.7;
		}

		.card-footer {
			margin-top: auto;
			padding-top: 1.5rem;
			border-top: 1px solid hsl(var(--border-color));
			font-size: 0.75rem;
			color: hsl(var(--text-secondary));
			font-style: italic;
		}

		.about-lore {
			background: linear-gradient(135deg, hsl(var(--accent-primary)), hsl(var(--accent-secondary)));
			border-radius: 32px;
			padding: 4rem;
			color: white;
			text-align: center;
		}

		.lore-banner h2 {
			font-size: 2.5rem;
			margin-bottom: 1.5rem;
		}

		.lore-banner p {
			font-size: 1.25rem;
			max-width: 600px;
			margin: 0 auto 2.5rem;
			opacity: 0.9;
		}

		.btn-lore {
			display: inline-block;
			background: white;
			color: hsl(var(--accent-primary));
			padding: 1rem 2.5rem;
			border-radius: 16px;
			font-weight: 900;
			transition: all 0.2s ease;
		}

		.btn-lore:hover {
			transform: scale(1.05);
			box-shadow: 0 10px 30px rgba(0,0,0,0.2);
		}
	</style>
</BaseLayout>
